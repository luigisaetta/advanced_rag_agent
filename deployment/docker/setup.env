# Single-source deployment configuration for Ubuntu/Linux VM.
# Copy to setup.env and edit values, then run deployment/docker/configure.py

# ----------------------------
# App public config (config.py)
# ----------------------------
CFG_AUTH=API_KEY
CFG_LLM_REGION=eu-frankfurt-1
CFG_EMBED_REGION=us-chicago-1
CFG_EMBED_MODEL_ID=cohere.embed-v4.0
CFG_COMPARTMENT_ID=ocid1.compartment.oc1..replace_me
CFG_LLM_MODEL_ID=openai.gpt-oss-120b
CFG_INTENT_MODEL_ID=openai.gpt-oss-120b
CFG_RERANKER_MODEL_ID=openai.gpt-oss-120b
CFG_POST_ANSWER_EVALUATION_MODEL_ID=openai.gpt-5.4
CFG_MAIN_LANGUAGE=same as the question
CFG_ENABLE_TRACING=True
CFG_CITATION_BASE_URL=/citations/

# -----------------------------------
# Private config (config_private.py)
# -----------------------------------
PRIV_VECTOR_DB_USER=AIUSER
PRIV_VECTOR_DB_PWD=replace_me
PRIV_VECTOR_WALLET_PWD=welcome1
PRIV_VECTOR_DSN=replace_me_medium
PRIV_APM_PUBLIC_KEY=replace_me

# Optional local fallback path used by config_private.py when VECTOR_WALLET_DIR env is not set.
PRIV_LOCAL_WALLET_DIR=/home/ubuntu/work-iren/wallet

# ----------------------------------------
# Docker host paths (docker-compose mounts)
# ----------------------------------------
DOCKER_WALLET_HOST_PATH=/home/ubuntu/work-iren/wallet
DOCKER_CITATIONS_HOST_PATH=/home/ubuntu/work-iren/pages
DOCKER_OCI_HOST_PATH=${HOME}/.oci

# Optional override for UI service env in compose.
DOCKER_CITATION_BASE_URL=/citations/
